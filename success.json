<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<canvas id="chart"></canvas>
<script>
fetch("metrics.json")
  .then(r => r.json())
  .then(data => {
    new Chart(document.getElementById("chart"), {
      type: "line",
      data: {
        labels: data.runs.map(r => r.id),
        datasets: [{
          label: "Duração",
          data: data.runs.map(r => r.duration)
        }]
      }
    });
  });
</script>
